<script>
    // Oculta el logotipo de Spline usando MutationObserver (sin polling)
    const hideLogo = (shadowRoot: ShadowRoot) => {
        if (shadowRoot.querySelector('#anti-spline-style')) return;

        const style = document.createElement('style');
        style.id = 'anti-spline-style';
        style.innerHTML = `
            #logo,
            a[href*="spline.design"],
            a[href*="spline"] {
                display: none !important;
                opacity: 0 !important;
                visibility: hidden !important;
                pointer-events: none !important;
            }
        `;
        shadowRoot.appendChild(style);

        const logo = shadowRoot.querySelector('#logo');
        if (logo) logo.setAttribute('style', 'display:none!important');
        const link = shadowRoot.querySelector('a[href*="spline"]');
        if (link) link.setAttribute('style', 'display:none!important');
    };

    const viewer = document.querySelector('spline-viewer');
    if (viewer) {
        // Si el shadowRoot ya existe, actuar de inmediato
        if (viewer.shadowRoot) {
            hideLogo(viewer.shadowRoot);
        }

        // MutationObserver para detectar cuándo se crea el shadowRoot
        const observer = new MutationObserver(() => {
            if (viewer.shadowRoot) {
                hideLogo(viewer.shadowRoot);
                // Observar cambios dentro del shadowRoot también
                const innerObserver = new MutationObserver(() => hideLogo(viewer.shadowRoot!));
                innerObserver.observe(viewer.shadowRoot, { childList: true, subtree: true });
                observer.disconnect();
            }
        });
        observer.observe(viewer, { childList: true, subtree: true, attributes: true });
    }
</script>

